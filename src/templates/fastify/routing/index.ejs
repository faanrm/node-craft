import { FastifyInstance } from 'fastify';

/**
 * Modular route registration for Fastify.
 * This file is automatically regenerated by NodeCraft.
 */
export default async function (app: FastifyInstance) {
<% for (const model of models) { %>
  await app.register(import('./<%= model.name.toLowerCase() %>.routes'), { prefix: '/api/<%= model.name.toLowerCase() %>s' });
<% } %>

  <% if (isAuth) { %>
  await app.register(import('./auth.routes'), { prefix: '/api/auth' });
  <% } %>
}
