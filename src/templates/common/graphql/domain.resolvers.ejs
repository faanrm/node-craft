import <%= model.name.toLowerCase() %>Service from '../../services/<%= model.name.toLowerCase() %>.service';

export const <%= model.name.toLowerCase() %>Resolvers = {
  Query: {
    get<%= model.name %>s: async (_: any, __: any, context: any) => {
      <% if (isAuth) { %>if (!context.user) throw new Error('Authentication required');<% } %>
      try {
        return await <%= model.name.toLowerCase() %>Service.findAll();
      } catch (error: any) {
        throw new Error(`Failed to fetch <%= model.name %>s: ${error.message}`);
      }
    },
    get<%= model.name %>: async (_: any, { id }: { id: string }, context: any) => {
      <% if (isAuth) { %>if (!context.user) throw new Error('Authentication required');<% } %>
      try {
        return await <%= model.name.toLowerCase() %>Service.findById(id);
      } catch (error: any) {
        throw new Error(`Failed to fetch <%= model.name %>: ${error.message}`);
      }
    },
  },
  Mutation: {
    create<%= model.name %>: async (_: any, { input }: { input: any }, context: any) => {
      <% if (isAuth) { %>if (!context.user) throw new Error('Authentication required');<% } %>
      try {
        return await <%= model.name.toLowerCase() %>Service.create(input);
      } catch (error: any) {
        throw new Error(`Failed to create <%= model.name %>: ${error.message}`);
      }
    },
    update<%= model.name %>: async (_: any, { id, input }: { id: string, input: any }, context: any) => {
      <% if (isAuth) { %>if (!context.user) throw new Error('Authentication required');<% } %>
      try {
        return await <%= model.name.toLowerCase() %>Service.update(id, input);
      } catch (error: any) {
        throw new Error(`Failed to update <%= model.name %>: ${error.message}`);
      }
    },
    delete<%= model.name %>: async (_: any, { id }: { id: string }, context: any) => {
      <% if (isAuth) { %>if (!context.user) throw new Error('Authentication required');<% } %>
      try {
        await <%= model.name.toLowerCase() %>Service.delete(id);
        return true;
      } catch (error: any) {
        throw new Error(`Failed to delete <%= model.name %>: ${error.message}`);
      }
    },
  },
};
