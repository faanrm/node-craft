version: '3.8'

services:
  app:
    build: .
    ports:
      - "${PORT:-3000}:3000"
    environment:
      - NODE_ENV=development
      - PORT=3000
      - DATABASE_URL=${DATABASE_URL}
      - JWT_SECRET=${JWT_SECRET}
    depends_on:
      - db

  db:
    <% if (database === 'MongoDB') { %>
    image: mongo:latest
    ports:
      - "27017:27017"
    volumes:
      - mongodb_data:/data/db
    <% } else if (database === 'PostgreSQL') { %>
    image: postgres:latest
    environment:
      - POSTGRES_USER=postgres
      - POSTGRES_PASSWORD=password
      - POSTGRES_DB=node_craft
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    <% } else if (database === 'MySQL') { %>
    image: mysql:latest
    environment:
      - MYSQL_ROOT_PASSWORD=password
      - MYSQL_DATABASE=node_craft
    ports:
      - "3306:3306"
    volumes:
      - mysql_data:/var/lib/mysql
    <% } %>

volumes:
  <% if (database === 'MongoDB') { %>
  mongodb_data:
  <% } else if (database === 'PostgreSQL') { %>
  postgres_data:
  <% } else if (database === 'MySQL') { %>
  mysql_data:
  <% } %>
