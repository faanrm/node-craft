import { Schema, model, Document } from 'mongoose';
import { I<%= model.name %> } from '../interfaces/<%= model.name.toLowerCase() %>.interface';

const <%= model.name %>Schema = new Schema<I<%= model.name %> & Document>({
<% model.fields.forEach(field => { %>
  <%= field.name %>: {
    type: <%- 
      field.isRelation ? 'Schema.Types.ObjectId' :
      field.type === 'String' ? 'String' : 
      field.type === 'Int' || field.type === 'Float' ? 'Number' : 
      field.type === 'Boolean' ? 'Boolean' : 
      field.type === 'DateTime' ? 'Date' : 'Schema.Types.Mixed' 
    %>,
    <% if (field.isRelation) { %>ref: '<%= field.relationModel %>',<% } %>
    required: <%= !field.isOptional %>,
    unique: <%= !!field.isUnique %>,
    <% if (field.minLength !== undefined) { %>minlength: <%= field.minLength %>,<% } %>
    <% if (field.maxLength !== undefined) { %>maxlength: <%= field.maxLength %>,<% } %>
  },
<% }) %>
}, {
  timestamps: true,
  versionKey: false
});

export const <%= model.name %>Model = model<I<%= model.name %> & Document>('<%= model.name %>', <%= model.name %>Schema);
