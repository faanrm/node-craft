import db from '../utils/db';
import jwt from 'jsonwebtoken';
import { UserModel } from '../models/user.model';
import { RoleModel } from '../models/role.model'; // Ensure RoleModel is imported
import { Secret, SignOptions } from 'jsonwebtoken';
import { UnauthorizedError, BadRequestError } from '../middleware/error.middleware';

export class AuthService {
  async register(userData: any) {
    <% if (orm === 'Prisma') { %>
    const existingUser = await db.user.findUnique({
      where: { email: userData.email }
    });
    <% } else if (orm === 'Mongoose') { %>
    const existingUser = await UserModel.findOne({ email: userData.email });
    <% } else { %>
    // Sequelize & TypeORM
    const existingUser = await UserModel.findOne({ where: { email: userData.email } });
    <% } %>

    if (existingUser) {
      throw new BadRequestError('User with this email already exists');
    }

    const hashedPassword = await UserModel.hashPassword(userData.password);

    // Default to 'user' role if none provided
    <% if (orm === 'Prisma') { %>
    let role = await db.role.findUnique({ where: { name: userData.role || 'user' } });
    if (!role) {
      role = await db.role.create({ data: { name: 'user' } });
    }

    const user = await db.user.create({
      data: {
        email: userData.email,
        password: hashedPassword,
        name: userData.name || null,
        roleId: role.id
      },
      include: { role: true }
    });
    <% } else if (orm === 'Mongoose') { %>
    // Check if role exists
    let role = await RoleModel.findOne({ name: userData.role || 'user' });
    if (!role) {
      role = await RoleModel.create({ name: 'user' });
    }

    const user = await UserModel.create({
      email: userData.email,
      password: hashedPassword,
      name: userData.name,
      roleId: role._id
    });
    // Populate for return
    await user.populate('roleId');
    <% } else if (orm === 'Sequelize') { %>
    // Sequelize
    let role = await RoleModel.findOne({ where: { name: userData.role || 'user' } });
    if (!role) {
      role = await RoleModel.create({ name: 'user' });
    }

    const user = await UserModel.create({
      email: userData.email,
      password: hashedPassword,
      name: userData.name,
      roleId: role.id
    });
    user.role = role; // Attach for return
    <% } else if (orm === 'TypeORM') { %>
    // TypeORM
    let role = await RoleModel.findOne({ where: { name: userData.role || 'user' } });
    if (!role) {
        role = RoleModel.create({ name: 'user' });
        await role.save();
    }

    const user = UserModel.create({
      email: userData.email,
      password: hashedPassword,
      name: userData.name,
      role: role
    });
    await user.save();
    <% } %>

    return {
      id: user.id,
      email: user.email,
      name: user.name,
      role: <% if (orm === 'Prisma') { %> user.role.name <% } else if (orm === 'Mongoose') { %> (user.roleId as any).name <% } else { %> (user.role || role).name <% } %>
    };
  }

  async login(email: string, password: string) {
    <% if (orm === 'Prisma') { %>
    const user = await db.user.findUnique({
      where: { email },
      include: { role: true }
    });
    <% } else if (orm === 'Mongoose') { %>
    const user = await UserModel.findOne({ email }).populate('roleId');
    <% } else if (orm === 'Sequelize') { %>
    const user = await UserModel.findOne({ where: { email }, include: [RoleModel] });
    <% } else if (orm === 'TypeORM') { %>
    const user = await UserModel.findOne({ where: { email }, relations: ['role'] });
    <% } %>

    if (!user) {
      throw new UnauthorizedError('Invalid email or password');
    }

    const isPasswordValid = await UserModel.comparePassword(password, user.password);

    if (!isPasswordValid) {
      throw new UnauthorizedError('Invalid email or password');
    }

    const jwtSecret = process.env.JWT_SECRET as Secret;
    const jwtExpiresIn = process.env.JWT_EXPIRES_IN || '7d';

    const token = jwt.sign(
      {
        userId: user.id,
        email: user.email,
        role: <% if (orm === 'Prisma') { %> user.role.name <% } else if (orm === 'Mongoose') { %> (user.roleId as any).name <% } else if (orm === 'Sequelize') { %> user.role.name <% } else { %> user.role.name <% } %>
      },
      jwtSecret,
      { expiresIn: jwtExpiresIn } as SignOptions
    );

    return {
      user: {
        id: user.id,
        email: user.email,
        name: user.name,
        role: <% if (orm === 'Prisma') { %> user.role.name <% } else if (orm === 'Mongoose') { %> (user.roleId as any).name <% } else if (orm === 'Sequelize') { %> user.role.name <% } else { %> user.role.name <% } %>
      },
      token
    };
  }
  
  async getUserById(userId: string) {
    <% if (orm === 'Prisma') { %>
    const user = await db.user.findUnique({
      where: { id: userId },
      include: { role: true }
    });
    <% } else if (orm === 'Mongoose') { %>
    const user = await UserModel.findById(userId).populate('roleId');
    <% } else if (orm === 'Sequelize') { %>
    const user = await UserModel.findByPk(userId, { include: [RoleModel] });
    <% } else if (orm === 'TypeORM') { %>
    const user = await UserModel.findOne({ where: { id: userId }, relations: ['role'] });
    <% } %>

    if (!user) {
      throw new BadRequestError('User not found');
    }

    return {
      id: user.id,
      email: user.email,
      name: user.name,
      role: <% if (orm === 'Prisma') { %> user.role.name <% } else if (orm === 'Mongoose') { %> (user.roleId as any).name <% } else if (orm === 'Sequelize') { %> user.role.name <% } else { %> user.role.name <% } %>
    };
  }
}

export default new AuthService();
