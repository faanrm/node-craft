<% if (orm === 'Prisma') { %>
import { Prisma, <%= model.name %> } from '@prisma/client';
import db from '../utils/db';
<% } else if (orm === 'TypeORM' || orm === 'Sequelize') { %>
import { <%= model.name %> } from '../models/<%= model.name.toLowerCase() %>.model';
import db from '../utils/db';
<% } else { %>
import { <%= model.name %>Model } from '../models/<%= model.name.toLowerCase() %>.model';
import db from '../utils/db';
<% } %>
import { Create<%= model.name %>Input, Update<%= model.name %>Input } from '../interfaces/<%= model.name.toLowerCase() %>.interface';

export class <%= model.name %>Service {
  async create(data: Create<%= model.name %>Input): Promise<any> {
    <% if (orm === 'Prisma') { %>
    return db.<%= model.name.toLowerCase() %>.create({ 
      data: data as any 
    });
    <% } else if (orm === 'TypeORM') { %>
    const entity = new <%= model.name %>();
    Object.assign(entity, data);
    return db.manager.save(entity);
    <% } else if (orm === 'Sequelize') { %>
    return <%= model.name %>.create(data);
    <% } else { %>
    return <%= model.name %>Model.create(data);
    <% } %>
  }

  async findAll(query: any = {}): Promise<any[]> {
    const { page = 1, limit = 10, sort, ...filters } = query;
    const skip = (Number(page) - 1) * Number(limit);
    const take = Number(limit);

    <% if (orm === 'Prisma') { %>
    const orderBy = sort ? { [sort.split(':')[0]]: sort.split(':')[1] } : undefined;
    return db.<%= model.name.toLowerCase() %>.findMany({
      where: filters,
      skip,
      take,
      orderBy
    });
    <% } else if (orm === 'TypeORM') { %>
    const [data] = await db.getRepository(<%= model.name %>).findAndCount({
      where: filters as any,
      skip,
      take,
      order: sort ? { [sort.split(':')[0]]: sort.split(':')[1] } : undefined
    });
    return data;
    <% } else if (orm === 'Sequelize') { %>
    const sortObj = sort ? { [sort.split(':')[0]]: sort.split(':')[1] === 'desc' ? 'DESC' : 'ASC' } : {};
    return <%= model.name %>.findAll({
      where: filters,
      limit: take,
      offset: skip,
      order: Object.entries(sortObj)
    });
    <% } else { %>
    const sortObj = sort ? { [sort.split(':')[0]]: sort.split(':')[1] === 'desc' ? -1 : 1 } : {};
    return <%= model.name %>Model.find(filters)
      .sort(sortObj as any)
      .skip(skip)
      .limit(take);
    <% } %>
  }

  async findById(id: string): Promise<any | null> {
    <% if (orm === 'Prisma') { %>
    return db.<%= model.name.toLowerCase() %>.findUnique({ 
      where: { id } 
    });
    <% } else if (orm === 'TypeORM') { %>
    return db.getRepository(<%= model.name %>).findOne({ where: { id } });
    <% } else if (orm === 'Sequelize') { %>
    return <%= model.name %>.findByPk(id);
    <% } else { %>
    return <%= model.name %>Model.findById(id);
    <% } %>
  }

  async update(id: string, data: Update<%= model.name %>Input): Promise<any> {
    <% if (orm === 'Prisma') { %>
    return db.<%= model.name.toLowerCase() %>.update({ 
      where: { id }, 
      data: data as any
    });
    <% } else if (orm === 'TypeORM') { %>
    const repo = db.getRepository(<%= model.name %>);
    const entity = await repo.findOne({ where: { id } });
    if (!entity) return null;
    Object.assign(entity, data);
    return repo.save(entity);
    <% } else if (orm === 'Sequelize') { %>
    const [updated] = await <%= model.name %>.update(data, { where: { id } });
    if (!updated) return null;
    return <%= model.name %>.findByPk(id);
    <% } else { %>
    return <%= model.name %>Model.findByIdAndUpdate(id, data, { new: true });
    <% } %>
  }

  async delete(id: string): Promise<any> {
    <% if (orm === 'Prisma') { %>
    return db.<%= model.name.toLowerCase() %>.delete({ 
      where: { id } 
    });
    <% } else if (orm === 'TypeORM') { %>
    const repo = db.getRepository(<%= model.name %>);
    const entity = await repo.findOne({ where: { id } });
    if (!entity) return false;
    await repo.remove(entity);
    return true;
    <% } else if (orm === 'Sequelize') { %>
    const deleted = await <%= model.name %>.destroy({ where: { id } });
    return !!deleted;
    <% } else { %>
    return <%= model.name %>Model.findByIdAndDelete(id);
    <% } %>
  }
}

export default new <%= model.name %>Service();