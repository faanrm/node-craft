import { <%= model.name %>Model } from '../models/<%= model.name.toLowerCase() %>.model';
import { z } from 'zod';

/**
 * Standard interface for <%= model.name %>
 */
export type I<%= model.name %> = z.infer<typeof <%= model.name %>Model.schema>;

/**
 * Input for creating a <%= model.name %>
 */
export type Create<%= model.name %>Input = Omit<I<%= model.name %>, 'id' | 'createdAt' | 'updatedAt'>;

/**
 * Input for updating a <%= model.name %>
 */
export type Update<%= model.name %>Input = Partial<Create<%= model.name %>Input>;